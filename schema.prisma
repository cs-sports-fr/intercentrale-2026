datasource db {
  provider = "postgres"
  url      = env("DATABASE_URL")
}

generator client {
  provider             = "prisma-client-py"
  recursive_type_depth = 5
}

model Sport {
  id               Int      @id @default(autoincrement())
  imageLink        String   @default("http://toss-images.s3.eu-west-3.amazonaws.com/sports/foot.jpeg")
  sport            String
  teams            Team[]  
  nbPlayersMin     Int      @default(1)
  nbPlayersMax     Int      @default(300)
  isCollective     Boolean  @default(true)
  nbOfTeams        Int      @default(64)
  admins           User[]

  description     String   @default("Sport description")
  description2    String   @default("Sport description 2")
 


  // New fields
  pointsperwin     Int      @default(0)
  pointsperdraw    Int      @default(0)
  pointsperdefeat  Int      @default(0) 


  // New fields 
  poolMatchLength  Int      @default(15)
  startTimeSunday  DateTime @default(now())
  pools            Pool[] 
  matches          Match[]  @relation("SportMatches")
  medals           Medal[] 
  placesSaturday Place[] @relation("SportPlacesSaturday")
  placesSunday   Place[] @relation("SportPlacesSunday")
  swimmingEvents  SwimmingEvent[]

  tiebreakerOrder  TiebreakerCriterion[] @default([HeadToHead, GoalsConceded, FairPlay, TournamentPoints, GoalsScored, GoalDifference,MatchesWon])

  // Conditions de restauration par sport
  // Petit déjeuner
  defaultBreakfastTimeSaturday   String?  // Horaire par défaut pour le petit déjeuner samedi (ex: "08:00")
  defaultBreakfastPlaceSaturdayId Int?    // Lieu par défaut pour le petit déjeuner samedi
  defaultBreakfastPlaceSaturday  Place?   @relation("BreakfastPlaceSaturday", fields: [defaultBreakfastPlaceSaturdayId], references: [id])
  defaultBreakfastTimeSunday     String?  // Horaire par défaut pour le petit déjeuner dimanche
  defaultBreakfastPlaceSundayId  Int?    // Lieu par défaut pour le petit déjeuner dimanche
  defaultBreakfastPlaceSunday    Place?   @relation("BreakfastPlaceSunday", fields: [defaultBreakfastPlaceSundayId], references: [id])
  
  // Déjeuner
  defaultLunchTimeSaturday        String?  // Horaire fixe pour le déjeuner samedi (ex: "13:00")
  defaultLunchPlaceSaturdayId      Int?     // Lieu par défaut pour le déjeuner samedi
  defaultLunchPlaceSaturday        Place?   @relation("LunchPlaceSaturday", fields: [defaultLunchPlaceSaturdayId], references: [id])
  defaultLunchTimeSunday           String?  // Horaire fixe pour le déjeuner dimanche (ex: "13:00")
  defaultLunchPlaceSundayId        Int?     // Lieu par défaut pour le déjeuner dimanche
  defaultLunchPlaceSunday          Place?   @relation("LunchPlaceSunday", fields: [defaultLunchPlaceSundayId], references: [id])
  
  // Conditions pour les finalistes du dimanche
  // Petit déjeuner finalistes
  defaultBreakfastTimeSundayFinalist     String?  // Horaire pour les finalistes dimanche
  defaultBreakfastPlaceSundayFinalistId Int?     // Lieu pour les finalistes dimanche
  defaultBreakfastPlaceSundayFinalist    Place?   @relation("BreakfastPlaceSundayFinalist", fields: [defaultBreakfastPlaceSundayFinalistId], references: [id])
  
  // Déjeuner finalistes
  defaultLunchTimeSundayFinalist         String?  // Horaire fixe pour les finalistes dimanche (ex: "14:00")
  defaultLunchPlaceSundayFinalistId      Int?     // Lieu pour les finalistes dimanche
  defaultLunchPlaceSundayFinalist        Place?   @relation("LunchPlaceSundayFinalist", fields: [defaultLunchPlaceSundayFinalistId], references: [id])
}

enum TiebreakerCriterion {
  TournamentPoints
  GoalDifference
  GoalsScored
  GoalsConceded
  HeadToHead
  FairPlay
  MatchesWon
}

enum TeamStatus {
    Incomplete
    Waiting
    Awaitingauthorization
    PrincipalList
    Validated
}

model Team {
  id                 Int           @id @default(autoincrement())
  name               String
  participants       Participant[]
  status             TeamStatus
  createdAt          DateTime      @default(now())
  sportId            Int
  sport              Sport         @relation(fields: [sportId], references: [id])
  teamAdminUserId    Int
  admin              User          @relation(fields: [teamAdminUserId], references: [id])
  schoolId           Int
  school             School        @relation(fields: [schoolId], references: [id])
  amountPaidInCents  Int           @default(0)
  amountToPayInCents Int           @default(0)
  Payment            Payment[]


  level              String        @default("")

  // New fields
  matchesTeamOne     Match[]       @relation("TeamOne")
  matchesTeamTwo     Match[]       @relation("TeamTwo")
  winnerMatches      Match[]       @relation("TeamWinner")  // Inverse relation for winner
  pools              Pool[]        @relation("TeamPools")   // Inverse relation for teams in Pool
  tournamentPoints   Int           @default(0) 
  poolmatcheswon     Int           @default(0) 
  poolmatcheslost    Int           @default(0)
  poolmatchesdraw    Int           @default(0)
  goalsScored        Int           @default(0)  
  goalsConceded      Int           @default(0) 
  goalDifference     Int           @default(0)
  isSelectedforKnockoutStage Boolean  @default(false)
  isConvocationGenerated Boolean @default(false)
  swimmingResults    SwimmingResult[]
  swimmingRelayResults SwimmingRelayResult[]
}

